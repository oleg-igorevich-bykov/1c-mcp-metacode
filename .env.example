# .env.example — пример файла окружения для настройки 
# Копируйте как .env и правьте значения под свою среду.
#
# Примечания по типам значений:
# - Логические: true/false, 1/0, yes/no, on/off (регистр не важен)
# - Списки/словари: указывать в формате JSON, например ["A","B"] или {"key":["v1","v2"]}
# - Пути: для контейнера путь по умолчанию /app/data (смонтированный volume)

############################
# MCP сервер
############################
# Хост и порт MCP сервера
MCP_HOST=0.0.0.0
MCP_PORT=6001

# HTTP-путь конечной точки
MCP_PATH=/mcp

# SQLite-настройки MCP runtime: видимость tools и будущие MCP-настройки
MCP_SETTINGS_SQLITE_PATH=storage/mcp/settings.sqlite

# Транспорт MCP: если true — SSE, иначе streamable-http
MCP_USE_SSE=false

# Задержка старта (сек), чтобы избежать одновременных handshake/DDL бурстов
STARTUP_DELAY_SECONDS=0


############################
# Проект
############################
# Человекочитаемое имя проекта (узел Project)
PROJECT_NAME=Accounting_30
# Дополнительные проекты доступные в сессии (JSON-массив). Первый проект в сессии — PROJECT_NAME.
# RELATED_PROJECTS=["ExchangeBase","AnotherProject"]


############################
# Настройки Neo4j
############################
# URI Neo4j (в docker-compose сервис базы называется 1c-neo4j, поэтому дефолт указывает на него)
NEO4J_URI=bolt://1c-neo4j:7687

# Имя пользователя БД
NEO4J_USERNAME=neo4j

# Пароль БД (обязательно)
NEO4J_PASSWORD=

# Имя базы (по умолчанию "neo4j")
NEO4J_DATABASE=neo4j

# Размер батча для пакетной загрузки (UNWIND), влияет на производительность загрузки
NEO4J_BATCH_SIZE=1000

# Максимальный размер батча для BSL-рутин с телом (адаптивное батчирование, МБ)
NEO4J_BSL_BATCH_MAX_MB=3.0

# Переоткрывать сессию каждые N чанков для предотвращения утечек памяти (0 = никогда)
NEO4J_SESSION_REFRESH_INTERVAL=100

# Размер батча для очистки проекта (FULL_METADATA_RELOAD) во избежание OOM (лимит транзакции 4ГБ)
NEO4J_CLEAR_PROJECT_BATCH_SIZE=10000

# Таймаут подключения (сек), срок жизни соединения (сек), размер пула, бюджет повторов транзакций (сек), fetch_size, таймаут получения коннекта (сек)
NEO4J_CONNECTION_TIMEOUT=180
NEO4J_MAX_CONN_LIFETIME=3600
NEO4J_POOL_SIZE=50
NEO4J_MAX_TX_RETRY_TIME=120
NEO4J_FETCH_SIZE=1000
NEO4J_POOL_ACQ_TIMEOUT=300


############################
# Загрузка метаданных и артефактов
############################
# Раскладка каталогов внутри смонтированного /app/data:
# - 'vanessa' (по умолчанию) — конвенция vanessa-bootstrap: data_directory — это корень
#   git-репозитория как он есть (просто git clone/pull, без промежуточного копирования):
#     data/src/cf/                  — основная конфигурация (XML-выгрузка)
#     data/src/cfe/<ИмяРасширения>/ — расширения, плоско (Configuration.xml сразу внутри)
#   Нет каталога metadata/ (текстового "Отчёта по конфигурации") — работает только с
#   METADATA_SOURCE=xml. ConfigDumpInfo.xml (для LOAD_METADATA_GUIDS) обычно в .gitignore —
#   кладите его поверх уже склонированного/подтянутого репозитория по путям
#   data/src/cf/ConfigDumpInfo.xml и data/src/cfe/<Name>/ConfigDumpInfo.xml (например,
#   overlay-шагом из отдельной orphan-ветки с ежесуточным дампом) — обогащение GUID
#   подхватится автоматически, никаких дополнительных настроек не требуется.
# - 'legacy' — прежняя раскладка:
#     data/metadata/               — .txt "Отчёт по конфигурации" (METADATA_SOURCE=txt)
#     data/code/                   — XML-выгрузка (METADATA_SOURCE=xml)
#     data/extensions/<Name>/{metadata,code}/ — расширения
PROJECT_LAYOUT=vanessa

# Источник метаданных: 'txt' — парсит metadata/*.txt; 'xml' — парсит XML-дамп напрямую
# ВНИМАНИЕ: смена значения на работающем проекте не подхватывается инкрементально —
# baseline хранится раздельно для txt и xml, incremental sync при несовпадении абортит
# цикл с ошибкой. Для смены источника поставьте FULL_METADATA_RELOAD=true и пересоздайте
# контейнер приложения (полная очистка Neo4j и переиндексация всех данных с нуля).
# METADATA_SOURCE=txt несовместим с PROJECT_LAYOUT=vanessa (нет каталога metadata/) —
# приложение откажется стартовать с понятной ошибкой.
METADATA_SOURCE=xml

# Режим стандартных атрибутов XML (только для METADATA_SOURCE=xml; игнорируется для txt):
# - 'listed' (по умолчанию) — сохранять только атрибуты, явно перечисленные в XML (безопасный режим)
# - 'materialized' — дополнительно материализовать отсутствующие стандартные атрибуты (диагностический режим)
XML_STANDARD_ATTRIBUTES_MODE=listed

# Принудительно выполнить полную перезагрузку метаданных при старте приложения:
# - true/false, 1/0, yes/no, on/off (регистр не важен)
# - Если true — будут очищены данные ТОЛЬКО текущего проекта (Project.name) перед загрузкой, а не вся БД Neo4j
# - Одноразово на контейнер: true выполняет full reload ОДИН раз для нового контейнера.
#   Обычный `docker restart` reload НЕ повторяет, даже если флаг остался true.
#   Для повторного full reload пересоздайте контейнер: docker compose up -d --force-recreate <service>.
#   Если оставить true, будущий recreate снова запустит full reload.
FULL_METADATA_RELOAD=false

# SCHEMA_MANAGED_EXTERNALLY: схема Neo4j (constraints/indexes/fulltext) управляется
# извне — контейнер НЕ создаёт её при загрузке метаданных.
# - false (по умолчанию) — контейнер сам создаёт схему при загрузке (standalone / один юнит).
# - true — предполагается, что флот выполнил `python main.py --ensure-schema` ОДИН раз
#   до старта проектных контейнеров. Убирает deadlock'и на schema-локах при одновременном
#   bootstrap'е многих контейнеров в общий Neo4j (Neo.TransientError.DeadlockDetected на
#   CREATE CONSTRAINT/INDEX). Векторные индексы всё равно досоздаются per-container.
#   Ставьте true ТОЛЬКО если в пайплайне флота есть шаг ensure-schema (см. инструкцию).
SCHEMA_MANAGED_EXTERNALLY=false

# Управление загрузкой предопределенных значений (Predefined.xml):
# - true — парсить и загружать предопределенные значения (по умолчанию)
# - false — пропустить этап Predefined.xml
LOAD_PREDEFINED_VALUES=true

# Управление загрузкой форм из Ext/Form.xml:
# - true — парсить и загружать определения форм (по умолчанию)
# - false — пропустить этап Form.xml (ускоряет загрузку, уменьшает объем графа)
LOAD_FORMS_FROM_XML=true

# Управление загрузкой прав ролей из Roles/*/Ext/Rights.xml:
# - true — загружать права ролей (по умолчанию)
# - false — пропустить импорт прав
LOAD_ROLE_RIGHTS=true

# Обогащение узлов GUID из ConfigDumpInfo.xml:
# - true — читать ConfigDumpInfo.xml и добавлять meta_uuid (по умолчанию)
# - false — пропустить чтение и обогащение
LOAD_METADATA_GUIDS=true

# Сканирование и импорт сигнатур BSL из файлов .bsl (модули, процедуры/функции, вызовы)
# - true — включить парсинг и загрузку BSL (по умолчанию)
# - false — пропустить этап BSL
LOAD_BSL_SIGNATURES=true

# Управление загрузкой справок Help/ru.html для объектов метаданных:
# - true — парсить и загружать справку (по умолчанию)
# - false — пропустить этап справки
LOAD_HELP_FROM_HTML=true

# Загрузка подписок на события из каталога EventSubscriptions/*.xml
# - true — включить парсинг и загрузку подписок (по умолчанию)
# - false — пропустить этап подписок
LOAD_EVENT_SUBSCRIPTIONS=true

# Загрузка расширений 1С из каталога extensions:
# - true — загружать расширения (по умолчанию)
# - false — пропустить этап расширений
LOAD_EXTENSIONS=true


############################
# Инкрементальная загрузка
############################
# Глобальный флаг: включает scheduler + one-shot incremental check после старта MCP.
# При false поведение проекта не меняется (только FULL_METADATA_RELOAD / bootstrap empty).
INCREMENTAL_LOADING_ENABLED=true

# Включает периодический re-check по интервалу. При false — только один one-shot цикл при старте.
INCREMENTAL_LOADING_SCHEDULE_ENABLED=true

# Интервал между циклами scheduler-а (только если schedule_enabled=true).
INCREMENTAL_LOADING_INTERVAL_MINUTES=60

# Путь к SQLite state. Используется как есть (Path(...)), симметрично BSL_CODE_SEARCH_SQLITE_PATH.
# В docker CWD=/app, поэтому 'storage/...' = '/app/storage/...' → named volume (storage_prj*),
# не bind-mounted /app/data.
INCREMENTAL_LOADING_STATE_PATH=/app/storage/incremental/incremental_loading.sqlite

# Overlap для XML watermark в секундах (защита от drift часов на диске).
INCREMENTAL_LOADING_OVERLAP_SECONDS=60

# Full reconcile — детектирует удалённые artifacts/XML descriptors. Применяется к metadata XML,
# к code artifacts (Form.xml/.bsl/Predefined/Help/...), к base и к extensions.
INCREMENTAL_FULL_RECONCILE_ENABLED=true
# Интервал между reconcile-циклами (часы).
INCREMENTAL_FULL_RECONCILE_INTERVAL_HOURS=24
# Окно времени для reconcile (HH:MM, локальное время).
INCREMENTAL_FULL_RECONCILE_WINDOW_START=02:00
INCREMENTAL_FULL_RECONCILE_WINDOW_END=05:00

# При обычном рестарте startup incremental моментально перехватывает scheduler_lock
# от предыдущего (упавшего) процесса. Scheduled scheduler по расписанию по-прежнему
# уважает lock и не запускается поверх идущего цикла.
#
# ВАЖНО: default=true рассчитан на single-container deployment, где один app-контейнер
# монопольно владеет своим INCREMENTAL_LOADING_STATE_PATH. scheduler_lock в state schema
# глобален по имени и не project-scoped — при multi-replica / shared-state развёртывании
# startup одного процесса будет отбирать lock у живого incremental другого процесса
# и приводить к split-brain writes в Neo4j. Для таких сценариев обязательно false.
INCREMENTAL_STARTUP_LOCK_TAKEOVER=true


############################
# Настройки параллельной обработки
############################
# Количество процессов для параллельного парсинга файлов
PROCESS_WORKERS=6

# Потоков на процесс (1-8, увеличить для I/O-bound задач)
THREADS_PER_PROCESS=4

# Переопределения для .bsl файлов (опционально, иначе используются PROCESS_WORKERS/THREADS_PER_PROCESS)
BSL_PROCESS_WORKERS=
BSL_THREADS_PER_PROCESS=

# Переопределения для .xml файлов (опционально, иначе используются PROCESS_WORKERS/THREADS_PER_PROCESS)
XML_PROCESS_WORKERS=
XML_THREADS_PER_PROCESS=

# Количество процессов для параллельного hashing и parse-only в incremental phase 2/3
# (artifact baseline + diff). Опционально; fallback: BSL_PROCESS_WORKERS → PROCESS_WORKERS → 4.
INCREMENTAL_ARTIFACT_WORKERS=


############################
# Embedding API настройки (для векторного поиска)
############################
# Базовый URL API для эмбеддингов:
#   - Openrouter: https://openrouter.ai/api/v1
#   - Локальный: http://host.docker.internal:1234/v1
EMBEDDING_API_BASE=

# Ключ доступа к API эмбеддингов
EMBEDDING_API_KEY=

# HTTP/HTTPS прокси для запросов к API эмбеддингов (опционально)
# Примеры: http://proxy.host:8080  /  http://user:pass@proxy.host:8080
EMBEDDING_PROXY=

# Модель эмбеддингов (например, qwen/qwen3-embedding-4b, perplexity/pplx-embed-v1-4b, text-embedding-harrier-oss-v1-0.6b, text-embedding-f2llm-v2-1.7b, text-embedding-jina-embeddings-v5-text-small-retrieval)
EMBEDDING_MODEL=

# Настройки процесса индексации
# Количество параллельных workers для генерации эмбеддингов (1-16, рекомендуется 4-8)
EMBEDDING_INDEXING_WORKERS=6

# Размер батча для запросов к API эмбеддингов (зависит от лимитов API)
EMBEDDING_BATCH_SIZE=100

# Размер батча для сохранения в Neo4j
EMBEDDING_SAVE_BATCH_SIZE=50

# Задержка между батчами в секундах (для rate limiting API)
EMBEDDING_RATE_LIMIT_DELAY=0.05

# Таймаут для запросов к API эмбеддингов (сек)
EMBEDDING_TIMEOUT_SECONDS=1800.0

# Максимум повторов при ошибках API эмбеддингов
EMBEDDING_MAX_RETRIES=3

# Базовая задержка для экспоненциального backoff (сек)
EMBEDDING_RETRY_BACKOFF_BASE_SECONDS=0.5

# Максимальная задержка для экспоненциального backoff (сек)
EMBEDDING_RETRY_BACKOFF_MAX_SECONDS=4.0

# Джиттер для задержек повторов (сек)
EMBEDDING_RETRY_JITTER_SECONDS=0.2

# При "No embedding data received" повторить batch с encoding_format=float (fallback, не отдельный retry)
EMBEDDING_FLOAT_FALLBACK_ON_NO_DATA=true

# Таймаут для получения информации о модели (сек, опционально)
EMBEDDING_MODEL_INFO_TIMEOUT_SECONDS=

# Порог косинусной похожести для отпечатков проекта (избегать повторной индексации)
EMBEDDING_FINGERPRINT_COSINE_THRESHOLD=0.999

# Профиль форматирования embedding-входа.
# auto — автоопределение по EMBEDDING_MODEL; иначе одно из:
#   none, openai, codestral, perplexity, nomic_text, nomic_code,
#   qwen3, f2llm_v2, harrier, bge_m3, e5, jina_v4, jina_v5, jina_code, gemini.
EMBEDDING_TEXT_FORMAT_PROFILE=auto

# Транспорт для embedding API.
# auto — определяется по EMBEDDING_API_BASE (openrouter.ai → openrouter,
# generativelanguage.googleapis.com / aiplatform.googleapis.com → gemini_native,
# иначе openai_compatible). Допустимые значения: auto, openai_compatible, openrouter, gemini_native.
EMBEDDING_TRANSPORT=auto

# Инструкция запроса для description-поиска (для instruction-aware профилей: qwen3, f2llm_v2, harrier).
EMBEDDING_DESCRIPTION_QUERY_INSTRUCTION=Given a search query, retrieve relevant passages that answer the query

# Определять максимум токенов через API; fallback на фиксированное значение
EMBEDDING_DETECT_CONTEXT_VIA_API=true

# Fallback для максимума входных токенов при отсутствии API-информации
EMBEDDING_MAX_INPUT_TOKENS_FALLBACK=4000

# Коэффициент безопасности для чанкинга (доля от max_tokens)
EMBEDDING_CHUNK_SAFETY_RATIO=0.9

# Fallback для символов на токен при отсутствии локального токенизатора
EMBEDDING_CHARS_PER_TOKEN_FALLBACK=2.0

# Перекрытие между чанками в символах
EMBEDDING_CHUNK_OVERLAP_CHARS=200

# Максимум чанков на объект (только для индексации; запросы не чанкуются)
EMBEDDING_MAX_CHUNKS_PER_OBJECT=12

# Стратегия пулинга эмбеддингов (только 'mean' поддерживается)
EMBEDDING_POOLING=mean

# L2-нормализация чанков перед пулингом
EMBEDDING_L2_NORM_CHUNKS=true

# L2-нормализация финального эмбеддинга
EMBEDDING_L2_NORM_FINAL=true


############################
# Настройки гибридного поиска
############################
# Веса для комбинирования результатов (должны в сумме давать 1.0)
# Fulltext вес: точные совпадения ключевых слов (рекомендуется 0.3)
HYBRID_SEARCH_FULLTEXT_WEIGHT=0.3
# Vector вес: семантическая близость (рекомендуется 0.7)
HYBRID_SEARCH_VECTOR_WEIGHT=0.7

# Доп. настройки гибридного поиска (fulltext + vector)
# Перевыбор кандидатов (oversampling) для устойчивой пагинации после слияния
HYBRID_OVERSAMPLE_FACTOR=3

# Нормализация и слияние результатов двух веток
# HYBRID_NORMALIZATION_STRATEGY: max|p95 — p95 уменьшает влияние выбросов (перцентильная нормализация)
HYBRID_NORMALIZATION_STRATEGY=p95
# HYBRID_FUSION_MODE: weighted|rrf — RRF не зависит от шкалы, удобен как робастный бэйзлайн
HYBRID_FUSION_MODE=weighted
# Константа k для RRF (типичные значения 20–120)
HYBRID_RRF_K=60

# Динамические веса per‑query (α для fulltext, β для vector; α+β=1)
HYBRID_DYNAMIC_WEIGHTS_ENABLED=true
# Ограничения для α (fulltext веса) при адаптации
HYBRID_ALPHA_MIN=0.2
HYBRID_ALPHA_MAX=0.8

# Кап для эффективной глубины (eff_k) извлекаемой из каждой ветки для стабилизации латентности на больших корпусах
HYBRID_EFF_K_CAP=300

# Адаптивный отсекатель "шума" для векторной ветки (порог похожести)
# Порог зависит от числа токенов в запросе: короткие — строже, длинные — мягче
VEC_MIN_SIM_SHORT_TOKENS=2
VEC_MIN_SIM_SHORT_VALUE=0.25
VEC_MIN_SIM_MEDIUM_TOKENS=5
VEC_MIN_SIM_MEDIUM_VALUE=0.20
VEC_MIN_SIM_DEFAULT=0.15

# Максимум различных категорий, передаваемых в description-поиск (vector ветка делает fan-out по категориям).
# Лимит проверяется ПОСЛЕ canonicalize/dedupe и до embedding-запроса.
VEC_MAX_CATEGORY_FILTERS=5


############################
# Настройки fulltext поиска
############################
# Адаптивные пороги min_score для fulltext поиска (зависят от числа токенов в запросе)
FT_MIN_SCORE_SHORT_TOKENS=2
FT_MIN_SCORE_SHORT_VALUE=2.0
FT_MIN_SCORE_MEDIUM_TOKENS=5
FT_MIN_SCORE_MEDIUM_VALUE=1.0
FT_MIN_SCORE_DEFAULT=0.1


############################
# Общие настройки rerank
############################
RERANK_MODEL=cohere/rerank-4-fast
RERANK_API_BASE=https://openrouter.ai/api/v1
RERANK_API_KEY=
RERANK_PROXY=
RERANK_TIMEOUT_SECONDS=60.0
RERANK_MAX_RETRIES=2


############################
# Настройки поиска по описаниям метаданных
############################
# Лимит по умолчанию для поиска описаний метаданных (ниже общего query_max_results для улучшения производительности)
METADATA_DESCRIPTION_SEARCH_DEFAULT_LIMIT=100

# Включить векторную индексацию для описаний метаданных (Metadata.doc_description)
ENABLE_METADATA_DESCRIPTION_EMBEDDING=false

# Rerank для find_metadata_objects(search_by="description").
METADATA_DESCRIPTION_RERANK_ENABLED=false
METADATA_DESCRIPTION_RERANK_TOP_K=50


############################
# Настройки поиска по описаниям процедур/функций
############################
# Лимит по умолчанию для поиска рутин по doc_description (search_bsl_routines mode="description");
# ниже общего query_max_results для улучшения производительности.
ROUTINE_DESCRIPTION_SEARCH_DEFAULT_LIMIT=100

# Включить векторную индексацию и эмбеддинги для описаний процедур/функций (Routine.doc_description)
# При включении автоматически создается векторный индекс и генерируются эмбеддинги
ENABLE_ROUTINE_DESCRIPTION_EMBEDDING=false

# Rerank для search_bsl_routines(mode="description").
ROUTINE_DESCRIPTION_RERANK_ENABLED=false
ROUTINE_DESCRIPTION_RERANK_TOP_K=50

# Outer-round retry для индексации эмбеддингов описаний процедур и метаданных.
# Общее число проходов фазы за один запуск (НЕ "1 + повторы"), общее для routine и
# metadata. 3 = основной проход + до двух дополнительных по оставшимся
# ..._embedding IS NULL записям. Значение <= 0 приводится к 1. Backoff применяется
# только между rounds и только если round завершился embedding-outage; он не
# заменяет EMBEDDING_MAX_RETRIES.
EMBEDDING_DESCRIPTION_INDEXING_MAX_ROUNDS=3
EMBEDDING_DESCRIPTION_INDEXING_ROUND_BACKOFF_SECONDS=20
EMBEDDING_DESCRIPTION_INDEXING_ROUND_BACKOFF_JITTER_SECONDS=5


############################
# BSL code search (семантический поиск по телу процедур/функций 1С)
############################
# Главный флаг: включает индексатор + MCP tool search_bsl_code + SQLite sidecar
ENABLE_BSL_CODE_SEARCH=true

# Включает embedding-часть (vector). При false sidecar SQLite/RLM строится, но vector path выключен,
# search всегда идёт через RLM. Effective vector gate = ENABLE_BSL_CODE_SEARCH AND ENABLE_BSL_CODE_EMBEDDING.
ENABLE_BSL_CODE_EMBEDDING=false

# Стратегия нарезки больших процедур (tree-sitter ast-safe sliding window).
# Точный набор параметров (window/overlap/min_overlap) закодирован в имени.
# Допустимые значения: ast_safe_sliding_3600_720_min480, ast_safe_sliding_2200_440_min300.
BSL_CODE_SPLIT_STRATEGY=ast_safe_sliding_3600_720_min480

# Размер batch для embedding API в Phase B. Код тяжелее коротких описаний,
# поэтому отдельная настройка независимо от EMBEDDING_BATCH_SIZE.
# Каждый API-запрос получает не более этого числа текстов.
BSL_CODE_EMBEDDING_BATCH_SIZE=16

# Compression стратегия для embedding text (none = raw default best-approach).
# Альтернативы: lexdedup_terms_cap1_lines_normprefix, lexdedup_cap1_nochainparts_lines_normprefix,
# rawbelow1000_lexdedup_terms_cap1_lines_normprefix (короткие юниты <1000 симв. остаются raw, длинные
# сжимаются), rawbelow1000_lexdedup_cap1_nochainparts_lines_normprefix.
BSL_CODE_COMPRESSION_STRATEGY=none

# Prompt mode для query/document embedding. auto = автоопределение по EMBEDDING_MODEL.
# Иначе одно из: none, jina-code-nl2code, jina-v5-retrieval, jina-v4-code,
# nomic-code-search, coderankembed-code-search, harrier-code-search, f2llm-code-search, qwen3-code-search.
BSL_CODE_EMBEDDING_PROMPT_MODE=auto

# Размер candidate pool из Neo4j vector top-K
BSL_CODE_VECTOR_TOP_K=50

# Дефолтный лимит результатов MCP tool
BSL_CODE_SEARCH_DEFAULT_LIMIT=5

# Search-visible coverage policy.
# Список owner_category, которые не эмбеддятся и скрыты в default-scope поиска.
# Чтобы искать в этих категориях, агент должен передать их явно в owner_categories.
# JSON-массив; пустой = ничего не исключать.
# Пример: BSL_CODE_EMBEDDING_EXCLUDED_OWNER_CATEGORIES=["Отчеты","Обработки"]
BSL_CODE_EMBEDDING_EXCLUDED_OWNER_CATEGORIES=[]
# Полное исключение регламентированных отчётов из search_bsl_code результатов.
BSL_CODE_SEARCH_EXCLUDE_REGULATED_REPORTS=true

# Rerank для search_bsl_code.
BSL_CODE_RERANK_ENABLED=false
BSL_CODE_RERANK_TOP_K=50

# Версии нарезки и structural extractor. Bump вручную при изменении алгоритма — триггерит полный reindex.
BSL_CODE_UNITS_VERSION=1
BSL_CODE_STRUCTURAL_EXTRACTOR_VERSION=1

# Путь к SQLite sidecar (contentless FTS5 для BM25/RLM/field-scoring).
# В Docker хранится на named volume, а не в bind-mounted /app/data.
BSL_CODE_SEARCH_SQLITE_PATH=/app/storage/search/bsl_code_search.sqlite
# При штатной схеме (каждый проект = свой сервис со своим named volume на /app/storage) переопределять
# путь не нужно: дефолт уже изолирован в томе каждого проекта.
# Строки ниже нужны ТОЛЬКО если несколько проектов делят ОДИН общий том — тогда задайте им разные пути,
# чтобы sidecar-базы не перезаписывали друг друга:
# BSL_CODE_SEARCH_SQLITE_PATH_PRJ1=/app/storage/search/prj1/bsl_code_search.sqlite
# BSL_CODE_SEARCH_SQLITE_PATH_PRJ2=/app/storage/search/prj2/bsl_code_search.sqlite

# Если true — fingerprint mismatch / source_state_hash mismatch / reindex_requested запускают полный rebuild
BSL_CODE_REINDEX_ON_FINGERPRINT_MISMATCH=true

# Размер batch для записи SQLite в Phase A (units per transaction). Уменьшает кол-во транзакций.
BSL_CODE_PHASE_A_WRITE_BATCH_UNITS=1000

# Размер batch для commit маленьких module boundary без mid-flush.
# Дополнительно ограничивается BSL_CODE_PHASE_A_WRITE_BATCH_UNITS по накопленным units.
BSL_CODE_PHASE_A_MODULE_COMMIT_BATCH=100

# Streaming Neo4j fetch для Phase A: количество routines за один body batch.
# Lightweight pass (без body) считает source_state_hash; затем keyset-paginated
# body batches ORDER BY (rel_path, routine_id) кормят ProcessPool workers.
BSL_CODE_ROUTINE_FETCH_BATCH_SIZE=1000

# Размер prefetch-очереди body batches между Neo4j fetch и ProcessPool workers.
# bounded — Neo4j I/O перекрывается с CPU работой workers, RAM ограничена.
BSL_CODE_ROUTINE_PREFETCH_BATCHES=2

# Phase A multiprocessing (CPU-bound: split + tokenize + structural extraction).
# Количество worker процессов в ProcessPoolExecutor.
BSL_CODE_PHASE_A_WORKERS=4

# Phase A work batch packing: количество routines на один call к worker.
BSL_CODE_PHASE_A_WORK_BATCH_ROUTINES=100

# Phase A size-aware cap: верхний лимит на сумму len(body) в одном work batch (MB).
# Pack идёт по min(WORK_BATCH_ROUTINES, WORK_BATCH_MAX_MB) — аналогично
# существующему NEO4J_BSL_BATCH_MAX_MB в BSL parsing pipeline.
BSL_CODE_PHASE_A_WORK_BATCH_MAX_MB=16

# Phase B async workers (I/O-bound: HTTP embedding + Neo4j vector write).
# Partition по fts_rowid % BSL_CODE_PHASE_B_WORKERS. Embedding HTTP вызывается
# через asyncio.to_thread, так что общая параллельность = N workers.
BSL_CODE_PHASE_B_WORKERS=4

# Startup overlap: Phase A + Phase B параллельно (ТОЛЬКО startup indexer)
# На больших конфигурациях startup/full rebuild складывает времена Phase A
# (SQLite/RLM) и Phase B (embedding кода через OpenRouter). Overlap эмбеддит уже
# зафиксированные Phase A units параллельно с Phase A; после Phase A — final
# catch-up по SQLite (source of truth), затем ONLINE-индекс + visibility sync +
# ready. Phase A НИКОГДА не зависит от embedding endpoint: при недоступности
# vector остаётся failed/degraded и догоняется retry-раундами/следующим циклом.
# Overlap включается только для startup indexer; scheduled/incremental/scoped не
# меняются (3 раунда, exponential backoff).
BSL_CODE_STARTUP_PHASE_B_OVERLAP_ENABLED=true
# Bounded queue Phase A -> controller (в батчах). Полная очередь → Phase A
# дропает нотификацию (catch-up добирает через SQLite), Phase A не блокируется.
BSL_CODE_STARTUP_PHASE_B_OVERLAP_QUEUE_BATCHES=4
# Гранулярность извлечения из очереди (drain-chunk). Перед провайдером chunk
# режется на sub-batches <= BSL_CODE_EMBEDDING_BATCH_SIZE.
BSL_CODE_STARTUP_PHASE_B_OVERLAP_CHUNK_ROUTINES=1000
BSL_CODE_STARTUP_PHASE_B_OVERLAP_CHUNK_UNITS=2000
# Startup Phase B (final catch-up) retry policy: длинное фиксированное окно, т.к.
# initial build терпит медленное восстановление endpoint. Scheduled = 3 раунда.
BSL_CODE_STARTUP_PHASE_B_MAX_ROUNDS=12
BSL_CODE_STARTUP_PHASE_B_ROUND_BACKOFF_MODE=fixed
BSL_CODE_STARTUP_PHASE_B_ROUND_BACKOFF_SECONDS=300
BSL_CODE_STARTUP_PHASE_B_ROUND_BACKOFF_JITTER_SECONDS=10
# Ожидание ONLINE для vec_bsl_code_unit перед commit ready (сек). Если startup
# probe был недоступен и индекс создаётся только после восстановления Phase B —
# ready не ставится, пока индекс не populated. Timeout → failed, retry next cycle.
BSL_CODE_VECTOR_INDEX_ONLINE_TIMEOUT_SECONDS=600

# Старые SQLite epoch удерживаются столько секунд после atomic switch (защита pinned read_epoch
# во время медленных запросов с query embedding). Пусто = auto: max(60, EMBEDDING_TIMEOUT_SECONDS*1.2).
SQLITE_EPOCH_RETENTION_SECONDS=


############################
# Object summary search (семантический поиск объектов метаданных по сгенерированной сводке по объекту)
############################
# Главный флаг. По умолчанию false — поведение проекта не меняется.
OBJECT_SUMMARY_ENABLED=false

# auto — фоновая генерация при старте; manual — только S0 reconcile, генерация запускается отдельно в веб консоли для каждого объекта.
OBJECT_SUMMARY_GENERATION_MODE=manual

# true — кнопка "Обновить" доступна в веб-консоли; false — обновлять существующие
# сводки вручную нельзя (кнопка "Создать" работает только для объектов без сводки).
OBJECT_SUMMARY_MANUAL_REGENERATION_ENABLED=true

# Категории объектов, для которых строится сводка. Только подмножество whitelist'а из 8.
OBJECT_SUMMARY_CATEGORIES=["Справочники","Документы","РегистрыСведений","РегистрыНакопления","Обработки","HTTPСервисы","БизнесПроцессы","Задачи"]

# Размер профиля, отправляемого LLM: small | medium | large
OBJECT_SUMMARY_PROFILE_SIZE_POLICY=medium

# LLM настройки для генерации сводок по объектам метаданных
OBJECT_SUMMARY_MODEL=openai/gpt-5.4-mini
OBJECT_SUMMARY_LLM_API_BASE=https://openrouter.ai/api/v1
OBJECT_SUMMARY_LLM_API_KEY=
OBJECT_SUMMARY_LLM_PROXY=
OBJECT_SUMMARY_LLM_TIMEOUT=300
OBJECT_SUMMARY_LLM_TEMPERATURE=0

# Параллелизм генерации
OBJECT_SUMMARY_GENERATION_WORKERS=2
OBJECT_SUMMARY_GENERATION_BATCH_SIZE=10
OBJECT_SUMMARY_GENERATION_MAX_RETRIES=3
# Общее число object-level попыток на один объект в одном запуске S1
# (1 = retry отключён). MAX_RETRIES относится к transient API ошибкам внутри LLM-клиента.
OBJECT_SUMMARY_GENERATION_ATTEMPTS=3
OBJECT_SUMMARY_RECONCILE_BATCH_SIZE=500
# false = смена версии профиля не запускает LLM-перегенерацию существующих summary
OBJECT_SUMMARY_REGENERATE_ON_PROFILE_VERSION_CHANGE=false

# Параллелизм S2 embedding (сам embedding идёт через общие EMBEDDING_* настройки)
OBJECT_SUMMARY_EMBEDDING_WORKERS=4
OBJECT_SUMMARY_EMBEDDING_BATCH_SIZE=8

# Расширения 1С
OBJECT_SUMMARY_GENERATE_FOR_EXTENSIONS=false
# Имена конфигураций расширений (или ["*"] чтобы брать все)
OBJECT_SUMMARY_EXTENSION_NAMES=["*"]
# own — только собственные объекты расширения; all — также заимствованные.
OBJECT_SUMMARY_EXTENSION_OBJECT_SCOPE=own

# Rerank для find_objects_by_summary.
OBJECT_SUMMARY_RERANK_ENABLED=false
OBJECT_SUMMARY_RERANK_TOP_K=50


############################
# Форматирование ответа
############################
# text | json | toon — формат итогового ответа в MCP
RESPONSE_FORMAT=toon

# Для JSON: кодировать узлы компактно (без labels/ids; только свойства)
RESPONSE_COMPACT_NODES=true

# Для JSON: компактные разделители (минимальный размер ответа)
RESPONSE_JSON_COMPACT=true

# Заменять повторяющиеся *_qn/*_config_name ссылками @qn:N/@config:N (уменьшает объём ответа; json и toon)
RESPONSE_COMPACT_REFS=true

############################
# Фильтры вывода метаданных
############################
# Удалять поля со значением пустая строка "" из объектов метаданных перед суммаризацией
METADATA_SUMMARIZE_DROP_EMPTY_STRINGS=true

# Исключать поля метаданных по имени (список строк, JSON)
# Пример: ["config_name","qualified_name","ИсторияДанных","doc_description_embedding","description_embedding"]
# Примечание: поля *_embedding содержат векторные представления и исключаются из вывода
METADATA_SUMMARIZE_EXCLUDE_FIELDS=["config_name","qualified_name","ИсторияДанных","doc_description_embedding","description_embedding","object_summary_embedding","object_summary_search_text","object_summary_path","console_search_name","console_search_name_norm","console_search_synonym","console_search_synonym_norm","console_search_type","console_search_type_norm","console_search_section"]

# Исключать пары (поле, конкретные значения) для метаданных — словарь JSON: { "<поле>": [<значения>...] }
# Пример:
# {"ПолнотекстовыйПоиск":["Использовать"]}
METADATA_SUMMARIZE_EXCLUDE_FIELD_VALUES={}


############################
# Ограничения и безопасность запросов (MCP)
############################
# Лимит по умолчанию для инструментов
QUERY_DEFAULT_LIMIT=100

# Максимум строк в выдаче (если LIMIT не указан, он будет добавлен/обрезан до этого значения)
QUERY_MAX_RESULTS=1000

# Максимум символов для возврата тела одной рутины (предотвращает огромные ответы)
MAX_RETURN_ROUTINE_BODY_LENGTH=10000


############################
# Веб-консоль
############################
# Включить веб-консоль на том же порту, что и MCP
WEB_CONSOLE_ENABLED=true

# Токен администратора (обязателен для доступа к странице "Система")
WEB_CONSOLE_ADMIN_TOKEN=

# SQLite база пользователей веб-консоли
WEB_CONSOLE_USERS_SQLITE_PATH=storage/console/users.sqlite

# JSON-массив пользователей, которые будут созданы при старте, если login еще отсутствует.
# [{"login":"ivan","display_name":"Иван","role":"user","token":"some-user-token","enabled":true}]
WEB_CONSOLE_SEED_USERS=[]

# HTTP-путь HTML-страницы консоли
WEB_CONSOLE_PATH=/console

# Префикс JSON API консоли
WEB_CONSOLE_API_PREFIX=/api/console


############################
# Встроенный агент веб-консоли
############################
# Главный флаг. По умолчанию false — консоль показывает отключенное состояние.
CONSOLE_AGENT_ENABLED=false

# OpenAI Agents SDK будет использовать Chat Completions model path для OpenAI-compatible endpoints.
# Для нескольких LLM-профилей создайте рядом с .env файл ./console_agent_llm.yaml
# по примеру console_agent_llm.example.yaml и раскомментируйте mount в docker-compose.yml.
# В контейнере файл должен быть доступен как /app/config/console_agent_llm.yaml.
# Если этот файл существует, профили/модели/endpoints/api_key берутся из него.
CONSOLE_AGENT_MODEL=deepseek/deepseek-v4-flash
CONSOLE_AGENT_LLM_API_BASE=https://openrouter.ai/api/v1
CONSOLE_AGENT_LLM_API_KEY=
CONSOLE_AGENT_LLM_PROXY=
CONSOLE_AGENT_LLM_TIMEOUT=180
CONSOLE_AGENT_LLM_TEMPERATURE=0.3
CONSOLE_AGENT_REASONING_EFFORT=medium
CONSOLE_AGENT_REASONING_SUMMARY=auto
CONSOLE_AGENT_SHOW_REASONING=true
CONSOLE_AGENT_MAX_TURNS=100
CONSOLE_AGENT_SESSION_SQLITE_PATH=storage/console_agent/sessions.sqlite
CONSOLE_AGENT_CHATS_SQLITE_PATH=storage/console_agent/chats.sqlite
CONSOLE_AGENT_MAX_CHATS_PER_USER=100
CONSOLE_AGENT_MCP_TIMEOUT=180
CONSOLE_AGENT_SESSION_ITEM_LIMIT=250
CONSOLE_AGENT_TOOL_OUTPUT_TRIMMER_ENABLED=true
CONSOLE_AGENT_TOOL_OUTPUT_RECENT_TURNS=5
CONSOLE_AGENT_TOOL_OUTPUT_MAX_CHARS=20000
CONSOLE_AGENT_TOOL_OUTPUT_PREVIEW_CHARS=20000

# Локальный MCP metacode всегда подключается кодом. Здесь можно скрыть отдельные
# локальные tools только от агента, не отключая их для внешних MCP-клиентов.
CONSOLE_AGENT_LOCAL_MCP_EXCLUDED_TOOLS=[]
# JSON-массив внешних MCP-серверов. Локальный metacode сюда не добавлять.
# Пример MCP 1С-Buddy, запущенного на хосте на порту 6002:
# timeout можно не указывать: тогда будет использован CONSOLE_AGENT_MCP_TIMEOUT.
# [{"name":"buddy","url":"http://host.docker.internal:6002/mcp","transport":"streamable_http","timeout":300,"excluded_tools":[]}]
CONSOLE_AGENT_EXTERNAL_MCP_SERVERS=[]


############################
# Отладка и аудит
############################
# Включить подробные логи (DEBUG уровень)
ENABLE_DEBUG=false

# Максимальная длина данных в debug-логах БД (символы, для параметров запросов)
# При DEBUG=true обрезает длинные параметры в логах Neo4j (например, массивы qualified_name)
# 0 — отключить обрезку, >0 — максимум символов (по умолчанию 100)
DEBUG_LOG_MAX_DATA_LENGTH=100

# Включить аудит-запись в файл logs/mcp_audit.log (в контейнере — /app/logs/mcp_audit.log)
ENABLE_LOG=false

# Детальное логирование параллельной обработки (ID процессов/потоков, жизненный цикл батчей)
# Включить для верификации истинного параллелизма; отключить в продакшене для снижения шума логов
ENABLE_PARALLEL_LOGGING=false

# Детальное логирование гибридного поиска (параметры поиска, счетчики результатов)
# Включить для отладки поведения гибридного поиска; отключить в продакшене для снижения шума логов
ENABLE_HYBRID_LOGGING=false


############################
# Управление памятью (runtime)
############################
# Ограничение числа glibc malloc arenas. Читается glibc ДО старта Python,
# поэтому применяется только при пересоздании контейнера приложения (recreate),
# а не на живой процесс. Меньше arenas — меньше фрагментации и удержанной памяти
# после пиковых аллокаций тяжёлых стадий (full load, BSL Phase A/B, embedding).
MALLOC_ARENA_MAX=4

# Явный gc.collect()+malloc_trim(0) на границах тяжёлых фаз (не в hot loops),
# чтобы вернуть ОС уже освобождённую внутри процесса память. false — отключить
# эти паузы (например, для сравнения производительности).
MEMORY_TRIM_ENABLED=true